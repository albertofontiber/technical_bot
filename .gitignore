# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
.claude/

# OS
.DS_Store
Thumbs.db

# Secrets
.env
.env.*
!.env.example

# Project artefacts — generated, not source
logs/
data/*
extracted_images/
evals/results/

# Catálogo de modelos: snapshot curado que el bot lee en runtime
# (src/rag/catalog.py) y que los tests necesitan. Es SOURCE-OF-TRUTH, no
# artefacto generado descartable → se versiona. Regenerar con
# scripts/build_model_catalog.py tras re-ingestar/añadir un fabricante.
!data/model_catalog.json

# Inventario de manuales: herramienta crítica de gap-hunting (M&A). Se versiona
# aunque viva en data/. Regenerar con scripts/update_inventario.py.
!data/Inventario_Manuales.xlsx

# Catálogo canónico de identidad (IDENTITY_CATALOG_CONTRACT §3, D1 REPO-FIRST
# aprobado por Alberto): la FUENTE es el repo — rollback = git revert; la DB
# deriva de aquí (F3). Editar SOLO vía scripts/catalog_store.py (la puerta valida).
# Gap cazado en s91: data/* lo dejaba fuera y el test de integración skippeaba.
!data/catalog

# Manuales descargados — grandes, no van al repo
Manuales_ES/
Manuales_Morley/
Manuales_Morley_Privado/
Manuales_Morley_Guias/
Manuales_Notifier/
Manuales_Notifier_Privado/
Manuales_Kidde/
Manuales_Aritech/
Manuales_Edwards/
Manuales_Otros/
Manuales_Detnov/
manuales/

# Source-of-truth index del scraper de guías (troubleshooting Morley)
# Se versiona aunque sea xlsx porque lo usa scripts/download_morley_guias.py
!Guia Tecnica Morley.xlsx

# Scratch
*.log
*.bak
_dry_run_results.json
tmp/

# Evals incompletos y payloads seeded grandes: se conservan localmente, pero
# los gates/recibos compactos son la evidencia versionada en Git. No borrar
# estos payloads sin ejecutar el cleanup gate de S130.
evals/*.partial.jsonl
evals/*.partial.*.claim
evals/s117_m27_loss_accounted_alignment_seed*_v1.json
evals/s117_m27_live_evidence_seed*_v1.json
evals/s117_m26_independent_audit_seed*_v1.json
evals/s117_m27_upstream_sql_budget_seed*_v1.json
evals/s117_m27_upstream_sql_budget_seed*_v2.json

# Raw vendor drops (zips de fabricantes, se procesan a Manuales_*)
*.zip

# Scratch de evals (logs intermedios, mini-tests por pregunta)
evals/_*

# Resultados por-k de test_bot_vs_gold (A/B runs reproducibles, no source).
# El baseline canónico evals/bot_vs_gold_results.yaml SÍ se versiona.
evals/bot_vs_gold_results_k*.yaml
evals/t1_surrogates_dump.jsonl

# Renders del gate-sample v4 (11MB, re-derivables byte-idénticos con verificación
# sha256 contra evals/s269_visual_utility_v4_gate_sample.json — que SÍ se versiona):
#   python scripts/s269_visual_utility_executor_v4.py --gate-sample --download-dir spotcheck_v4
spotcheck_v4/

# Renders de los gate-samples s271 (piloto + resto + re-gates): re-derivables
# byte-idénticos con verificación sha256 contra evals/s271_visual_utility_gate_sample*.json
# (que SÍ se versionan): scripts/s271_render_backfill.py --gate-sample --download-dir ...
spotcheck_s271/
spotcheck_s271_resto/
spotcheck_s271_resto_v2/

# Backup local del saneo de una línea corrupta del checkpoint de labels
# (solape de dos appends durante un corte; el canónico es el .jsonl saneado).
evals/*.bak_corrupt
