+def test_carveout_eviction_tail_vector_only(monkeypatch):
+    """(s103) Pass-through OVERSIZE con canales mixtos: el sitio del aside lo paga la COLA
+    del canal VECTOR — el top-coseno vectorial y los keyword-stamps sobreviven (el bug
+    CRÍTICO r1 era arrasar el canal entero cuando merged>top_k)."""
+    rows = [
+        _chunk("k1", "DOC-K", 0.85, channel="MODEL"),
+        _chunk("vtop", "DOC-T", 0.84),
+        _chunk("k2", "DOC-K", 0.80, channel="MODEL"),
+        _chunk("v2", "DOC-A", 0.66),
+        _chunk("v3", "DOC-A", 0.60),
+        _chunk("v4", "DOC-B", 0.58),
+        _chunk("v5", "DOC-B", 0.55),
+        _chunk("hyq1", "DOC-B", 0.46, hyq=True),
+    ]
+    _patch_pipeline(monkeypatch, rows)
+
+    top_k = 5
+    out = rt.retrieve_chunks("¿Cómo se resetea la CAD-150?", top_k=top_k)
+    ids = [c["id"] for c in out]
+    assert len(out) <= top_k
+    assert "hyq1" in ids, "el aside sobrevive"
+    assert "vtop" in ids, "el TOP-coseno VECTOR jamás se evicta (es sole-rep y head)"
+    assert "k1" in ids and "k2" in ids, "los keyword-stamps NO pagan la cuota"
+    assert "v3" not in ids, "paga la COLA del canal VECTOR (posición, no score)"
+
+
+def test_carveout_eviction_skips_boosted_and_swapped(monkeypatch):
+    """(s103) Las exclusiones: _hyq_boosted (hit real con señal-pregunta) y
+    _swapped_from_surrogate (rescate A3/enunciados) NO se evictan aunque estén en la
+    cola — paga el siguiente VECTOR real hacia arriba."""
+    rows = [
+        _chunk("k1", "DOC-K", 0.85, channel="MODEL"),
+        _chunk("v1", "DOC-A", 0.70),
+        _chunk("b1", "DOC-A", 0.52, boosted=True),
+        _chunk("sw1", "DOC-A", 0.50, swapped=True),
+        _chunk("hyq1", "DOC-B", 0.46, hyq=True),
+    ]
+    _patch_pipeline(monkeypatch, rows)
+
+    top_k = 4
+    out = rt.retrieve_chunks("¿Cómo se resetea la CAD-150?", top_k=top_k)
+    ids = [c["id"] for c in out]
+    assert "b1" in ids and "sw1" in ids, "boosted/swapped protegidos de la eviction"
+    assert "v1" not in ids, "paga el siguiente VECTOR real hacia arriba"
+    assert "hyq1" in ids and len(out) <= top_k
+
+
+def test_carveout_eviction_respects_sole_representative(monkeypatch):
+    """(s103, contrato G1 — convergencia dúo r2) El ÚNICO chunk VECTOR de un source no se
+    evicta aunque sea la cola: la garantía per-source del interleave sobrevive a la
+    eviction."""
+    rows = [
+        _chunk("k1", "DOC-K", 0.85, channel="MODEL"),
+        _chunk("v2", "DOC-B", 0.60),
+        _chunk("v3", "DOC-B", 0.55),
+        _chunk("v1", "DOC-A", 0.50),   # sole-rep de DOC-A, en la cola
+        _chunk("hyq1", "DOC-C", 0.46, hyq=True),
+    ]
+    _patch_pipeline(monkeypatch, rows)
+
+    top_k = 4
+    out = rt.retrieve_chunks("¿Cómo se resetea la CAD-150?", top_k=top_k)
+    ids = [c["id"] for c in out]
+    assert "v1" in ids, "el sole-representative de DOC-A sobrevive (contrato, no claim)"
+    assert "v3" not in ids, "paga la cola del source con ≥2 chunks"
