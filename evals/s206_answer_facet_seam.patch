diff --git a/src/rag/answer_facets.py b/src/rag/answer_facets.py
new file mode 100644
index 0000000..4758477
--- /dev/null
+++ b/src/rag/answer_facets.py
@@ -0,0 +1,137 @@
+"""Query-archetype answer ledger for source-faithful generation.
+
+The ledger reuses the existing versioned retrieval archetype classifier. It
+does not select evidence, extract target values, inspect evaluation IDs or add
+facts to an answer. It only asks the writer to check generic answer facets
+against the chunks that are already served.
+"""
+from __future__ import annotations
+
+import os
+import re
+from functools import lru_cache
+from pathlib import Path
+from typing import Any
+
+import yaml
+
+from .query_facets import expand_query_facets
+from .retriever import extract_product_models
+
+ROOT = Path(__file__).resolve().parents[2]
+DEFAULT_CONFIG = ROOT / "config/answer_facets_v1.yaml"
+
+
+def answer_facet_ledger_mode() -> str:
+    """Return the strict runtime mode; the default is byte-inert."""
+    raw = os.getenv("ANSWER_FACET_LEDGER", "off").strip().lower()
+    aliases = {"": "off", "0": "off", "false": "off", "no": "off"}
+    mode = aliases.get(raw, raw)
+    if mode not in {"off", "on"}:
+        raise RuntimeError(
+            f"ANSWER_FACET_LEDGER={raw!r} no reconocido (off|on)"
+        )
+    return mode
+
+
+@lru_cache(maxsize=4)
+def _load(path_string: str) -> dict[str, Any]:
+    path = Path(path_string)
+    payload = yaml.safe_load(path.read_text(encoding="utf-8"))
+    if payload.get("schema") != "answer_facets_v1":
+        raise RuntimeError("unsupported answer facet schema")
+    classifier = payload.get("classifier")
+    if not isinstance(classifier, str) or not (ROOT / classifier).is_file():
+        raise RuntimeError("answer facet classifier is missing")
+    policy = payload.get("policy")
+    if not isinstance(policy, dict) or not all(
+        policy.get(key) is True
+        for key in (
+            "include_only_source_supported",
+            "material_to_query_only",
+            "preserve_relations_and_qualifiers",
+            "internal_ledger_not_user_visible",
+            "require_explicit_recognized_product",
+        )
+    ):
+        raise RuntimeError("answer facet policy must fail closed")
+    archetypes = payload.get("archetypes")
+    if not isinstance(archetypes, dict) or not archetypes:
+        raise RuntimeError("answer facet archetypes are missing")
+    enabled = payload.get("enabled_archetypes")
+    if (
+        not isinstance(enabled, list)
+        or not enabled
+        or any(not isinstance(item, str) for item in enabled)
+        or len(set(enabled)) != len(enabled)
+        or set(enabled) != set(archetypes)
+    ):
+        raise RuntimeError("enabled answer facet archetypes must match configured subset")
+    for archetype, spec in archetypes.items():
+        checks = spec.get("checks") if isinstance(spec, dict) else None
+        label = spec.get("label") if isinstance(spec, dict) else None
+        if not isinstance(archetype, str) or not isinstance(label, str) or not label:
+            raise RuntimeError("invalid answer facet archetype")
+        if (
+            not isinstance(checks, list)
+            or not 2 <= len(checks) <= 6
+            or any(
+                not isinstance(item, dict)
+                or not isinstance(item.get("id"), str)
+                or not re.fullmatch(r"[a-z][a-z0-9_]*", item["id"])
+                or not isinstance(item.get("text"), str)
+                or not item["text"].strip()
+                for item in checks
+            )
+            or len({item["id"] for item in checks}) != len(checks)
+        ):
+            raise RuntimeError(f"invalid checks for answer archetype {archetype}")
+        configured_text = " ".join([label, *(item["text"] for item in checks)])
+        if re.search(r"\d", configured_text):
+            raise RuntimeError("answer facets cannot inject numeric target values")
+        if re.search(r"\b[A-Z]{2,}[- ]?\d+[A-Z0-9-]*\b", configured_text):
+            raise RuntimeError("answer facets cannot inject product codes")
+    classifier_payload = yaml.safe_load(
+        (ROOT / classifier).read_text(encoding="utf-8")
+    )
+    classifier_ids = {
+        row.get("id") for row in classifier_payload.get("archetypes") or []
+    }
+    if not set(archetypes) < classifier_ids:
+        raise RuntimeError("answer facets must be a strict classifier subset")
+    return payload
+
+
+def classify_answer_archetype(
+    query: str, config_path: Path = DEFAULT_CONFIG
+) -> str | None:
+    """Classify with the existing retrieval ontology, without a second router."""
+    payload = _load(str(config_path.resolve()))
+    classifier = ROOT / payload["classifier"]
+    return expand_query_facets(query, config_path=classifier)["archetype"]
+
+
+def render_answer_facet_ledger(
+    query: str | None, config_path: Path = DEFAULT_CONFIG
+) -> str:
+    """Render generic internal checks for one routed query, or an empty string."""
+    if answer_facet_ledger_mode() == "off" or not query:
+        return ""
+    payload = _load(str(config_path.resolve()))
+    if not extract_product_models(query):
+        return ""
+    archetype = classify_answer_archetype(query, config_path=config_path)
+    spec = payload["archetypes"].get(archetype or "")
+    if not spec:
+        return ""
+    checks = "\n".join(f"- {item['text']}." for item in spec["checks"])
+    return f"""
+
+LEDGER INTERNO DE COBERTURA ({spec['label']}):
+Antes de redactar, recorre TODOS los fragmentos servidos y comprueba estas facetas:
+{checks}
+Incluye solo facetas materialmente relacionadas con la pregunta y respaldadas por los
+fragmentos. Conserva siempre la relacion exacta entre campo, valor, condicion, efecto,
+unidad, limite y excepcion; no conviertas palabras cercanas en una relacion que la fuente
+no afirma. Si una faceta no esta respaldada, omitela sin rellenarla ni mencionarla. No
+muestres este ledger ni lo conviertas en una seccion de la respuesta."""
