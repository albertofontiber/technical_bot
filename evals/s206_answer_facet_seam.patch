index 0000000..0fdc418
--- /dev/null
+++ b/tests/test_s206_answer_facet_ab.py
@@ -0,0 +1,42 @@
+from scripts.s141_source_bound_technical_obligations import TARGET_KINDS, answer_map
+from scripts.s206_answer_facet_ab_preflight import _source_canary, build_cohort
+from scripts.s206_score_answer_facet_ab import (
+    _relation_scores,
+    hp017_cardinality_contradiction,
+    invalid_citations,
+)
+from src.rag.retriever import extract_product_models
+
+
+def test_source_canary_binding_rule_adds_recognized_identity():
+    row = _source_canary()
+    assert row["qid"] == "s147_src_05"
+    assert extract_product_models(row["question"]) == ["SGD-151"]
+    assert row["question_transform"] == "prefix_en_el_product_model_lowercase_original_initial"
+
+
+def test_invalid_citations_are_range_checked():
+    assert invalid_citations("Correcto [F1][F3]", 3) == []
+    assert invalid_citations("Mal [F0][F4][F4]", 3) == [0, 4]
+
+
+def test_hp017_cardinality_requires_explicit_disclosure():
+    contradictory = (
+        "Hay seis tipos: Fijo, Estándar, No Silenc., Est. Ext., RetExtStd, "
+        "No Sil. Ext y SinRetExt."
+    )
+    disclosed = contradictory + " El manual dice seis, pero la tabla enumera siete opciones."
+    assert hp017_cardinality_contradiction(contradictory)
+    assert not hp017_cardinality_contradiction(disclosed)
+
+
+def test_hp017_short_answer_does_not_false_trigger():
+    assert not hp017_cardinality_contradiction("Seleccione el tipo Fijo [F1].")
+
+
+def test_relation_scorer_accepts_every_frozen_target_row():
+    answers = answer_map()
+    targets = {row["qid"]: row for row in build_cohort() if row["role"] == "target"}
+    for qid, row in targets.items():
+        scored = _relation_scores(row, answers[qid])
+        assert set(scored) == TARGET_KINDS[qid]
