diff --git a/tests/test_answer_facets.py b/tests/test_answer_facets.py
new file mode 100644
index 0000000..72794f9
--- /dev/null
+++ b/tests/test_answer_facets.py
@@ -0,0 +1,110 @@
+import re
+from pathlib import Path
+
+import pytest
+import yaml
+
+from src.rag.answer_facets import (
+    DEFAULT_CONFIG,
+    answer_facet_ledger_mode,
+    classify_answer_archetype,
+    render_answer_facet_ledger,
+)
+from src.rag.generator import SYSTEM_PROMPT, _assemble_system
+
+
+def test_default_off_is_byte_inert(monkeypatch):
+    monkeypatch.delenv("ANSWER_FACET_LEDGER", raising=False)
+    monkeypatch.setenv("GENERATOR_PROMPT_VARIANT", "base")
+    assert render_answer_facet_ledger("¿Cómo se diagnostica una avería?") == ""
+    assert _assemble_system("¿Cómo se diagnostica una avería?") == SYSTEM_PROMPT
+
+
+def test_invalid_mode_fails_fast(monkeypatch):
+    monkeypatch.setenv("ANSWER_FACET_LEDGER", "enabled")
+    with pytest.raises(RuntimeError, match="off\\|on"):
+        answer_facet_ledger_mode()
+
+
+@pytest.mark.parametrize(
+    ("query", "expected"),
+    [
+        ("¿Qué barrera se usa en una instalación intrínsecamente segura?", "intrinsic_safety"),
+        ("¿Qué resistencia de fin de línea usa este lazo?", "loop_eol_topology"),
+        ("¿Cuántos detectores admite cada lazo?", "capacity_quantity"),
+        ("¿Es compatible este detector con la central?", "compatibility"),
+        ("¿Cómo cambio la batería sin perder la configuración?", "replace_without_loss"),
+        ("¿Cómo se conecta el módulo al lazo?", "connect_install_wire"),
+        ("¿Qué autonomía deben cubrir las baterías?", "battery_sizing"),
+        ("El equipo muestra un fallo; ¿cómo lo diagnostico?", "fault_reset_recovery"),
+        ("¿Cómo programo una salida con retardo?", "program_delay_cause_effect"),
+    ],
+)
+def test_reuses_existing_classifier_for_all_archetypes(query, expected):
+    assert classify_answer_archetype(query) == expected
+
+
+def test_neutral_specification_query_remains_inert(monkeypatch):
+    monkeypatch.setenv("ANSWER_FACET_LEDGER", "on")
+    query = "¿Cuáles son las características técnicas del equipo?"
+    assert classify_answer_archetype(query) is None
+    assert render_answer_facet_ledger(query) == ""
+
+
+def test_fault_ledger_is_generic_source_bound_and_internal(monkeypatch):
+    monkeypatch.setenv("ANSWER_FACET_LEDGER", "on")
+    rendered = render_answer_facet_ledger(
+        "Después de resetear el ASD535 no vuelve a normal; ¿qué compruebo?"
+    )
+    assert "diagnostico y recuperacion" in rendered
+    assert "valores nominales" in rendered
+    assert "requisitos previos de seguridad" in rendered
+    assert "No\nmuestres este ledger" in rendered
+    assert "incluye solo" in rendered.casefold()
+    assert not re.search(r"\b(?:AM-8200|ASD535|RP1r|PEARL|cat018|hp002)\b", rendered)
+
+
+def test_programming_ledger_preserves_relation_shaped_checks(monkeypatch):
+    monkeypatch.setenv("ANSWER_FACET_LEDGER", "on")
+    rendered = render_answer_facet_ledger(
+        "¿Cómo se programa una regla causa-efecto en la ID3000 para activar una salida?"
+    )
+    for expected in (
+        "campos exactos",
+        "instruccion de entrada",
+        "accion de salida",
+        "valores por defecto",
+        "reglas contradictorias",
+        "puesta en marcha",
+    ):
+        assert expected in rendered
+
+
+def test_ambiguous_fault_query_is_inert(monkeypatch):
+    monkeypatch.setenv("ANSWER_FACET_LEDGER", "on")
+    assert render_answer_facet_ledger("Después de resetear el panel no vuelve a normal") == ""
+
+
+def test_unmeasured_archetype_is_inert_even_with_product(monkeypatch):
+    monkeypatch.setenv("ANSWER_FACET_LEDGER", "on")
+    assert render_answer_facet_ledger("¿Cuántos detectores admite cada lazo de la ID3000?") == ""
+
+
+def test_config_is_measured_classifier_subset_and_has_no_target_literals():
+    payload = yaml.safe_load(DEFAULT_CONFIG.read_text(encoding="utf-8"))
+    classifier_path = Path(__file__).resolve().parents[1] / payload["classifier"]
+    classifier = yaml.safe_load(classifier_path.read_text(encoding="utf-8"))
+    classifier_ids = {row["id"] for row in classifier["archetypes"]}
+    assert set(payload["enabled_archetypes"]) == set(payload["archetypes"])
+    assert set(payload["archetypes"]) == {
+        "fault_reset_recovery",
+        "program_delay_cause_effect",
+    }
+    assert set(payload["archetypes"]) < classifier_ids
+    configured = " ".join(
+        text
+        for spec in payload["archetypes"].values()
+        for text in [spec["label"], *(item["text"] for item in spec["checks"])]
+    )
+    assert not re.search(r"\d", configured)
+    assert not re.search(r"AM-8200|ASD535|RP1r|PEARL|cat018|hp002|hp011|hp017", configured)
diff --git a/tests/test_s206_answer_facet_ab.py b/tests/test_s206_answer_facet_ab.py
