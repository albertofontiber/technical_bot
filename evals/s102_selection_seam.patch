+"""s102/L4 — test de PARIDAD del bloque de SELECCIÓN (GENERATOR_SELECTION_BLOCK).
+
+Mismo contrato que test_s69_prompt_variant: el aislamiento se prueba a nivel de
+CONSTRUCCIÓN-DEL-PROMPT ($0, determinista, DEC-015). Cubre además la COMPOSICIÓN con
+fidelity (bloques independientes) y el parser estricto (lección s96-H3: un typo no
+puede medio-apagar en silencio — a diferencia del variant legacy, que cae a base).
+"""
+import os
+
+import pytest
+
+os.environ.setdefault("CHUNKS_TABLE", "chunks_v2")
+
+from src.rag.generator import (  # noqa: E402
+    _FIDELITY_BLOCK,
+    _SELECTION_BLOCK,
+    SYSTEM_PROMPT,
+    _assemble_system,
+    _selection_block_on,
+)
+
+
+def test_default_sin_env_es_inerte(monkeypatch):
+    monkeypatch.delenv("GENERATOR_SELECTION_BLOCK", raising=False)
+    monkeypatch.setenv("GENERATOR_PROMPT_VARIANT", "base")
+    assert _assemble_system() == SYSTEM_PROMPT           # prod intacto
+
+
+def test_on_anade_el_bloque(monkeypatch):
+    monkeypatch.setenv("GENERATOR_PROMPT_VARIANT", "base")
+    monkeypatch.setenv("GENERATOR_SELECTION_BLOCK", "on")
+    out = _assemble_system()
+    assert out == SYSTEM_PROMPT + _SELECTION_BLOCK
+    assert out.startswith(SYSTEM_PROMPT)
+    assert "CONSULTA DE SELECCIÓN SOBRE UNA FAMILIA" in out
+
+
+def test_composicion_con_fidelity(monkeypatch):
+    # bloques independientes: fidelity + selection = base + ambos, en ese orden
+    monkeypatch.setenv("GENERATOR_PROMPT_VARIANT", "fidelity")
+    monkeypatch.setenv("GENERATOR_SELECTION_BLOCK", "on")
+    assert _assemble_system() == SYSTEM_PROMPT + _FIDELITY_BLOCK + _SELECTION_BLOCK
+
+
+def test_off_no_contiene_el_bloque(monkeypatch):
+    monkeypatch.setenv("GENERATOR_SELECTION_BLOCK", "off")
+    monkeypatch.setenv("GENERATOR_PROMPT_VARIANT", "base")
+    assert "CONSULTA DE SELECCIÓN" not in _assemble_system()
+
+
+def test_parser_estricto(monkeypatch):
+    monkeypatch.delenv("GENERATOR_SELECTION_BLOCK", raising=False)
+    assert _selection_block_on() is False
+    monkeypatch.setenv("GENERATOR_SELECTION_BLOCK", "on")
+    assert _selection_block_on() is True
+    monkeypatch.setenv("GENERATOR_SELECTION_BLOCK", "enabled")   # typo → fail-fast
+    with pytest.raises(RuntimeError):
+        _selection_block_on()
+
+
+def test_runtime_toggle(monkeypatch):
+    monkeypatch.setenv("GENERATOR_PROMPT_VARIANT", "base")
+    monkeypatch.setenv("GENERATOR_SELECTION_BLOCK", "on")
+    a = _assemble_system()
+    monkeypatch.setenv("GENERATOR_SELECTION_BLOCK", "off")
+    b = _assemble_system()
+    assert a != b and b == SYSTEM_PROMPT
+
+
+def test_bloque_no_contradice_tipo2_ni_clarificacion(monkeypatch):
+    # el bloque COMPLEMENTA TIPO 2: la regla de clarificación abierta sigue presente,
+    # y el bloque declara explícitamente el límite de su excepción.
+    monkeypatch.setenv("GENERATOR_PROMPT_VARIANT", "base")
+    monkeypatch.setenv("GENERATOR_SELECTION_BLOCK", "on")
+    out = _assemble_system()
+    assert "FORMATO CUANDO PIDES CLARIFICACIÓN" in out    # TIPO 2 intacto
+    assert "no lo sustituye" in out                       # el bloque se declara complemento
+    assert "ya instalado" in out                          # límite de la excepción declarado
